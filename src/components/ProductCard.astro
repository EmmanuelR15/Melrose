---
interface Props {
  product: {
    id: string;
    nombre: string;
    precio: number;
    imagen_url: string;
    categoria: string;
    descripcion?: string;
  }
}

const { product } = Astro.props;
const formatter = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  minimumFractionDigits: 0,
});
---

<article class="product-card">
  <div class="product-image-wrap">
    <div class="product-image-mask"></div>
    <img src={product.imagen_url} alt={product.nombre} loading="lazy" class="product-img" />
  </div>
  
  <div class="product-info">
    <div class="product-header">
      <h3 class="product-name">{product.nombre}</h3>
      <p class="product-category">{product.categoria}</p>
    </div>
    <p class="product-price">{formatter.format(product.precio)}</p>
    <button class="add-to-cart" data-id={product.id}>AGREGAR</button>
  </div>
</article>

<style>
  .product-card {
    background: transparent;
    border: 1.5px solid rgba(0, 212, 255, 0.2);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .product-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(0, 212, 255, 0.1),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 1;
  }

  .product-card:hover {
    border-color: var(--cyan);
    box-shadow: 
      0 0 20px rgba(0, 212, 255, 0.4),
      inset 0 0 20px rgba(0, 212, 255, 0.05),
      0 0 40px rgba(0, 212, 255, 0.2);
    transform: translateY(-8px) scale(1.02);
  }

  .product-card:hover::before {
    opacity: 1;
  }

  .product-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: linear-gradient(135deg, #0f0f0f, #0a0a0a);
    border-bottom: 1px solid rgba(0, 212, 255, 0.1);
  }

  .product-image-mask {
    position: absolute;
    inset: 0;
    background: var(--negro);
    z-index: 2;
    transform-origin: top;
    will-change: transform;
  }

  .product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.05);
    will-change: transform;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .product-card:hover .product-img {
    transform: scale(1.2) rotate(1deg);
  }

  .product-card:hover .product-image-mask {
    animation: imagePulse 0.5s ease-out forwards;
  }

  .product-info {
    padding: 1.5rem;
    display: grid;
    gap: 0.8rem;
    background: rgba(10, 10, 10, 0.8);
    transition: background 0.3s ease;
  }

  .product-card:hover .product-info {
    background: rgba(0, 212, 255, 0.02);
  }

  .product-name {
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    transition: color 0.3s ease;
  }

  .product-card:hover .product-name {
    color: var(--cyan);
    text-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
  }

  .product-category {
    font-size: 0.7rem;
    color: var(--cyan);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .product-price {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--blanco);
  }

  .add-to-cart {
    background: transparent;
    border: 1.5px solid var(--cyan);
    color: var(--blanco);
    padding: 0.7rem 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 
      inset 0 0 10px rgba(0, 212, 255, 0.1),
      0 0 10px rgba(0, 212, 255, 0.2);
  }

  .add-to-cart::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--cyan);
    transition: left 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: -1;
  }

  .add-to-cart:hover {
    color: var(--negro);
    border-color: var(--cyan);
    box-shadow: 
      0 0 20px rgba(0, 212, 255, 0.6),
      inset 0 0 20px rgba(0, 212, 255, 0.2);
    transform: scale(1.05);
  }

  .add-to-cart:hover::before {
    left: 0;
  }

  .add-to-cart:active {
    transform: scale(0.95);
  }

  @keyframes imagePulse {
    from {
      transform: scaleY(1);
      opacity: 1;
    }
    to {
      transform: scaleY(0);
      opacity: 0;
    }
  }

  @media (max-width: 768px) {
    .product-card:hover {
      transform: translateY(-4px) scale(1.01);
      box-shadow: 
        0 0 15px rgba(0, 212, 255, 0.3),
        inset 0 0 15px rgba(0, 212, 255, 0.02);
    }

    .product-img {
      transform: scale(1.02);
    }

    .product-card:hover .product-img {
      transform: scale(1.1);
    }
  }
</style>
