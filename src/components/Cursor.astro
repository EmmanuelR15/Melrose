---
// Custom Magnetic Cursor Component
---

<div class="custom-cursor" id="customCursor"></div>

<script>
  import { gsap } from 'gsap';

  const initCursor = () => {
    // Only run on non-touch devices
    if (window.matchMedia('(pointer: coarse)').matches) return;

    const cursor = document.getElementById('customCursor');
    if (!cursor) return;

    // Center starting point and ensure all transform properties are explicitly initialized
    gsap.set(cursor, { 
      xPercent: -50, 
      yPercent: -50, 
      scale: 1,
      transformOrigin: "center center",
      force3D: true
    });

    // QuickTo for super smooth performance
    let xTo, yTo, scaleTo;
    try {
      xTo = gsap.quickTo(cursor, "x", {duration: 0.3, ease: "power3"});
      yTo = gsap.quickTo(cursor, "y", {duration: 0.3, ease: "power3"});
      scaleTo = gsap.quickTo(cursor, "scale", {duration: 0.3, ease: "power3.out", overwrite: true});
    } catch (e) {
      console.warn("GSAP quickTo initialization prevented");
    }

    const handleMouseMove = (e) => {
      // Check if cursor still exists in DOM before animating
      if (!document.getElementById('customCursor')) return;
      
      xTo(e.clientX);
      yTo(e.clientY);
      
      if (cursor && (cursor.style.opacity === "0" || cursor.style.opacity === "")) {
        try {
          gsap.to(cursor, {opacity: 1, duration: 0.2});
        } catch (e) {}
      }
    };

    const handleMouseOver = (e) => {
      if (!document.getElementById('customCursor')) return;
      
      const target = e.target as HTMLElement;
      if (!target) return;
      
      const isClickable = target.closest('a') || target.closest('button') || target.classList.contains('interactive');
      
      // Nuclear Scale Fix
      if (cursor && scaleTo && gsap.getProperty(cursor, "scale") !== undefined) {
        try {
          if (isClickable) {
            scaleTo(2.5);
            cursor.classList.add('active');
          } else {
            scaleTo(1);
            cursor.classList.remove('active');
          }
        } catch (e) {
          console.warn("GSAP scale animation silenced in transition");
        }
      }
    };

    window.addEventListener("mousemove", handleMouseMove);
    document.addEventListener("mouseover", handleMouseOver);

    // Cleanup function for Astro transitions
    const cleanup = () => {
      window.removeEventListener("mousemove", handleMouseMove);
      document.removeEventListener("mouseover", handleMouseOver);
      gsap.killTweensOf(cursor);
      console.log("🧹 Cleanup: Cursor listeners and animations stopped");
    };

    document.addEventListener('astro:before-preparation', cleanup, { once: true });
  };

  // Run on first load and after each page transition
  document.addEventListener('astro:page-load', initCursor);
</script>

<style>
  .custom-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 20px;
    height: 20px;
    border: 2px solid var(--rojo);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    opacity: 0; /* Hidden until first move */
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .custom-cursor.active {
    background-color: rgba(192, 57, 43, 0.15); /* Soft red fill */
    border-color: rgba(192, 57, 43, 0.8);
  }

  @media (pointer: coarse) {
    .custom-cursor {
      display: none !important;
    }
  }
</style>
