---
// Map section with Google Maps embed - dark styled
---

<section class="map-section" id="ubicacion">
  <div class="map-container">
    <div class="map-header">
      <h2>ENCONTRANOS</h2>
      <div class="contact-links">
        <a href="https://www.instagram.com/melrose.stw/?hl=es-la" target="_blank" rel="noopener noreferrer" class="contact-link" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
          <span>INSTAGRAM</span>
        </a>
        <a href="https://wa.me/5493624645328" target="_blank" rel="noopener noreferrer" class="contact-link" aria-label="WhatsApp">
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor">
            <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.06 3.978L0 16l4.104-1.076a7.864 7.864 0 0 0 3.89 1.013h.005c4.368 0 7.926-3.558 7.93-7.93a7.897 7.897 0 0 0-2.328-5.681zM7.994 14.52a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
          </svg>
          <span>WHATSAPP</span>
        </a>
      </div>
    </div>
    <div class="map-wrap">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d500!2d-58.70895!3d-27.0422421!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjfCsDAyJzMyLjEiUyA1OMKwNDInMzIuMiJX!5e0!3m2!1ses!2sar!4v1"
        width="100%" height="400" style="border:0; filter: grayscale(100%) invert(90%) contrast(90%);" allowfullscreen loading="lazy">
      </iframe>
    </div>
  </div>
</section>

<style>
  .map-section {
    background: var(--negro);
    border-top: 1px solid var(--borde);
    padding: 0;
  }

  .map-container {
    max-width: 100%;
  }

  .map-header {
    text-align: center;
    padding: 4rem 2rem 2rem;
  }

  .map-header h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--blanco);
    margin-bottom: 2rem;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--gris);
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .contact-link svg {
    transition: transform 0.3s ease, stroke 0.3s ease;
  }

  .contact-link:hover {
    color: var(--rojo);
  }

  .contact-link:hover svg {
    stroke: var(--rojo);
    transform: translateY(-3px);
  }

  .contact-link span {
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
  }

  .contact-link:hover span {
    border-color: var(--rojo);
  }

  .map-wrap {
    width: 100%;
    line-height: 0;
  }

  .map-wrap iframe {
    width: 100%;
    display: block;
  }

  @media (max-width: 768px) {
    .map-header {
      padding: 3rem 1rem 1.5rem;
    }

    .map-wrap iframe {
      height: 300px;
    }
  }
</style>
