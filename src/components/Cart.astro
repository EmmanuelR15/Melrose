---
// Carrito interactivo - necesita ser renderizado del lado del cliente
---

<div class="cart-wrapper" id="cartWrapper">
  <div class="cart-badge" id="cartBadge">0</div>
  <button class="cart-button" id="cartButton" aria-label="Abrir carrito">
    <span class="cart-icon">BAG</span>
  </button>

  <aside class="cart-drawer" id="cartDrawer">
    <div class="cart-header">
      <h3>TU CARRITO</h3>
      <button class="close-cart" id="closeCart">✕</button>
    </div>
    <div class="cart-items" id="cartItems"></div>
    <div class="cart-footer">
      <div class="cart-total">
        <span>TOTAL</span>
        <strong id="cartTotal">$ 0</strong>
      </div>
      <button class="btn-primary checkout-btn" id="checkoutBtn">FINALIZAR COMPRA</button>
    </div>
  </aside>
</div>

<div class="cart-overlay" id="cartOverlay"></div>

<script type="module">
  // Cart Management Logic
  class CartManager {
    constructor() {
      this.cart = JSON.parse(localStorage.getItem('cart') || '[]');
      this.updateUI();
      this.setupEventListeners();
    }

    setupEventListeners() {
      const cartButton = document.getElementById('cartButton');
      const closeCart = document.getElementById('closeCart');
      const cartOverlay = document.getElementById('cartOverlay');
      const checkoutBtn = document.getElementById('checkoutBtn');

      cartButton?.addEventListener('click', () => this.toggleCart());
      closeCart?.addEventListener('click', () => this.closeCart());
      cartOverlay?.addEventListener('click', () => this.closeCart());
      checkoutBtn?.addEventListener('click', () => this.checkout());

      // Add to cart buttons
      document.addEventListener('click', (e) => {
        if (e.target.classList.contains('add-to-cart')) {
          this.addToCart(e.target);
        }
      });
    }

    addToCart(button) {
      const productId = button.dataset.id;
      const productName = button.closest('.product-card')?.querySelector('.product-name')?.textContent || 'Producto';
      const productPrice = button.closest('.product-card')?.querySelector('.product-price')?.textContent || '0';

      const item = {
        id: productId,
        name: productName,
        price: this.parsePrice(productPrice),
        quantity: 1
      };

      const existing = this.cart.find(p => p.id === productId);
      if (existing) {
        existing.quantity++;
      } else {
        this.cart.push(item);
      }

      this.save();
      this.updateUI();
      this.openCart();
    }

    removeFromCart(productId) {
      this.cart = this.cart.filter(p => p.id !== productId);
      this.save();
      this.updateUI();
    }

    updateQuantity(productId, quantity) {
      const item = this.cart.find(p => p.id === productId);
      if (item) {
        item.quantity = Math.max(1, quantity);
        this.save();
        this.updateUI();
      }
    }

    parsePrice(priceStr) {
      return parseFloat(priceStr.replace(/[^\d.-]/g, '')) || 0;
    }

    updateUI() {
      const badge = document.getElementById('cartBadge');
      const itemsContainer = document.getElementById('cartItems');
      const total = document.getElementById('cartTotal');

      if (badge) {
        badge.textContent = this.cart.reduce((sum, item) => sum + item.quantity, 0);
      }

      if (itemsContainer) {
        itemsContainer.innerHTML = this.cart.length
          ? this.cart.map(item => `
              <div class="cart-item">
                <div class="item-info">
                  <h4>${item.name}</h4>
                  <p class="item-price">$ ${item.price.toLocaleString('es-AR')}</p>
                </div>
                <div class="item-controls">
                  <input type="number" value="${item.quantity}" min="1" data-id="${item.id}" class="qty-input">
                  <button class="remove-btn" data-id="${item.id}">Eliminar</button>
                </div>
              </div>
            `).join('')
          : '<p class="empty-cart">Tu carrito está vacío</p>';

        // Add event listeners to quantity inputs and remove buttons
        itemsContainer.querySelectorAll('.qty-input').forEach(input => {
          input.addEventListener('change', (e) => {
            this.updateQuantity(e.target.dataset.id, parseInt(e.target.value));
          });
        });

        itemsContainer.querySelectorAll('.remove-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            this.removeFromCart(e.target.dataset.id);
          });
        });
      }

      if (total) {
        const totalAmount = this.cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
        total.textContent = `$ ${totalAmount.toLocaleString('es-AR')}`;
      }
    }

    toggleCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.toggle('active');
    }

    openCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.add('active');
    }

    closeCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.remove('active');
    }

    checkout() {
      if (this.cart.length === 0) {
        alert('Tu carrito está vacío');
        return;
      }

      const cartText = this.cart
        .map(item => `${item.name} x${item.quantity} - $ ${(item.price * item.quantity).toLocaleString('es-AR')}`)
        .join('%0A');

      const total = this.cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
      const message = `Hola, me gustaría comprar:%0A${cartText}%0ATotal: $ ${total.toLocaleString('es-AR')}`;

      window.open(`https://wa.me/?text=${message}`, '_blank');
    }

    save() {
      localStorage.setItem('cart', JSON.stringify(this.cart));
    }
  }

  // Initialize cart on page load
  new CartManager();
</script>

<style>
  .cart-wrapper {
    position: relative;
  }

  .cart-button {
    background: transparent;
    border: none;
    color: var(--blanco);
    cursor: pointer;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    position: relative;
  }

  .cart-badge {
    position: absolute;
    top: -8px;
    right: -8px;
    background: var(--rojo);
    color: var(--blanco);
    border-radius: 50%;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 600;
  }

  .cart-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 999;
  }

  .cart-overlay.active {
    display: block;
  }

  .cart-drawer {
    position: fixed;
    right: -100%;
    top: 0;
    width: 100%;
    max-width: 400px;
    height: 100%;
    background: var(--negro);
    border-left: 1px solid var(--borde);
    z-index: 1001;
    transition: right 0.3s ease;
    display: flex;
    flex-direction: column;
    padding-top: 70px;
  }

  .cart-drawer.active {
    right: 0;
  }

  .cart-drawer.active ~ .cart-overlay {
    display: block;
  }

  .cart-header {
    padding: 2rem;
    border-bottom: 1px solid var(--borde);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cart-header h3 {
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .close-cart {
    background: transparent;
    border: none;
    color: var(--blanco);
    font-size: 1.5rem;
    cursor: pointer;
  }

  .cart-items {
    flex: 1;
    overflow-y: auto;
    padding: 2rem;
  }

  .cart-item {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--borde);
  }

  .item-info h4 {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .item-price {
    font-size: 0.9rem;
    color: var(--rojo);
  }

  .item-controls {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .qty-input {
    width: 50px;
    padding: 0.5rem;
    background: var(--negro-suave);
    border: 1px solid var(--borde);
    color: var(--blanco);
    text-align: center;
  }

  .remove-btn {
    background: transparent;
    border: 1px solid var(--borde);
    color: var(--blanco);
    padding: 0.5rem 1rem;
    font-size: 0.7rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .remove-btn:hover {
    background: var(--rojo);
    border-color: var(--rojo);
  }

  .empty-cart {
    text-align: center;
    opacity: 0.6;
    font-size: 0.9rem;
  }

  .cart-footer {
    padding: 2rem;
    border-top: 1px solid var(--borde);
  }

  .cart-total {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .checkout-btn {
    width: 100%;
  }

  @media (max-width: 768px) {
    .cart-drawer {
      max-width: 100%;
    }
  }
</style>
