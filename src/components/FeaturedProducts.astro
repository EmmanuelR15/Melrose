---
import ProductCard from './ProductCard.astro';

// Load products from localStorage with admin priority
function loadAdminProducts() {
  try {
    const stored = localStorage.getItem('admin_products');
    return stored ? JSON.parse(stored) : null;
  } catch (error) {
    console.error('Error loading admin products:', error);
    return null;
  }
}

// Fallback products with destacado field
const fallbackProducts = [
  {
    id: 'fallback-1',
    nombre: 'URBAN TEE CLASSIC',
    precio: 45000,
    imagen_url: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=600&h=800&fit=crop',
    categoria: 'REMERAS',
    descripcion: 'Remera clásica urbana con logo bordado',
    stock: 15,
    destacado: true
  },
  {
    id: 'fallback-2',
    nombre: 'STREET HOODIE PRO',
    precio: 78000,
    imagen_url: 'https://images.unsplash.com/photo-1556821840-3a8f3ea9f747?w=600&h=800&fit=crop',
    categoria: 'BUZOS',
    descripcion: 'Buzo premium con capucha y bolsillos frontales',
    stock: 8,
    destacado: true
  },
  {
    id: 'fallback-3',
    nombre: 'CARGO PANTS BLACK',
    precio: 95000,
    imagen_url: 'https://images.unsplash.com/photo-1541099649105-f69ad21f3242?w=600&h=800&fit=crop',
    categoria: 'PANTALONES',
    descripcion: 'Pantalones cargo con múltiples bolsillos',
    stock: 12,
    destacado: false
  },
  {
    id: 'fallback-4',
    nombre: 'URBAN CAP BLACK',
    precio: 35000,
    imagen_url: 'https://images.unsplash.com/photo-1576871337622-101f8921f9e1?w=600&h=800&fit=crop',
    categoria: 'ACCESORIOS',
    descripcion: 'Gorra urbana con logo bordado',
    stock: 20,
    destacado: false
  }
];

// Get products with priority: 1. Admin localStorage, 2. Fallback
let allProducts = loadAdminProducts() || fallbackProducts;
const featuredProducts = allProducts.filter(p => p.destacado === true).slice(0, 4);
---

<section class="featured-products">
  <div class="container">
    <div class="section-header">
      <h2>DESTACADOS</h2>
      <p>Las piezas más representativas de la temporada</p>
    </div>

    {featuredProducts.length > 0 ? (
      <div class="products-grid">
        {featuredProducts?.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    ) : (
      <div class="empty-featured">
        <div class="glitch-text">NEW DROP COMING SOON</div>
      </div>
    )}
  </div>
</section>

<style>
  .featured-products {
    padding: 6rem 0;
    background: var(--negro);
    border-top: 1px solid var(--borde);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--blanco);
    margin-bottom: 1rem;
    font-family: 'Bebas Neue', sans-serif;
  }

  .section-header p {
    font-size: 1rem;
    color: var(--gris);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    max-width: 100%;
  }

  .empty-featured {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 6rem 0;
    min-height: 300px;
  }

  .glitch-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--blanco);
    text-transform: uppercase;
    position: relative;
    animation: glitch 2s infinite;
  }

  .glitch-text::before,
  .glitch-text::after {
    content: 'NEW DROP COMING SOON';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .glitch-text::before {
    animation: glitch-1 0.5s infinite;
    color: var(--cyan);
    z-index: -1;
  }

  .glitch-text::after {
    animation: glitch-2 0.5s infinite;
    color: var(--rojo);
    z-index: -2;
  }

  @keyframes glitch {
    0%, 100% {
      text-shadow: 
        0 0 5px rgba(192, 57, 43, 0.5),
        0 0 10px rgba(0, 255, 255, 0.3);
    }
    25% {
      text-shadow: 
        2px 0 5px rgba(192, 57, 43, 0.5),
        -2px 0 10px rgba(0, 255, 255, 0.3);
    }
    50% {
      text-shadow: 
        -2px 0 5px rgba(192, 57, 43, 0.5),
        2px 0 10px rgba(0, 255, 255, 0.3);
    }
    75% {
      text-shadow: 
        0 0 5px rgba(192, 57, 43, 0.5),
        0 0 10px rgba(0, 255, 255, 0.3);
    }
  }

  @keyframes glitch-1 {
    0%, 100% {
      clip-path: inset(0 0 0 0);
    }
    25% {
      clip-path: inset(20% 0 30% 0);
    }
    50% {
      clip-path: inset(50% 0 20% 0);
    }
    75% {
      clip-path: inset(10% 0 60% 0);
    }
  }

  @keyframes glitch-2 {
    0%, 100% {
      clip-path: inset(0 0 0 0);
    }
    25% {
      clip-path: inset(60% 0 10% 0);
    }
    50% {
      clip-path: inset(20% 0 50% 0);
    }
    75% {
      clip-path: inset(30% 0 20% 0);
    }
  }

  @media (max-width: 768px) {
    .featured-products {
      padding: 4rem 0;
    }

    .container {
      padding: 0 1rem;
    }

    .section-header {
      margin-bottom: 3rem;
    }

    .products-grid {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
    }
  }
</style>