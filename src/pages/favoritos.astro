---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase.js';

// Obtener productos del wishlist desde localStorage (client-side)
// Esta página se renderiza principalmente del lado del cliente
---

<Layout title="Mis Favoritos | MELROSE">
  <main class="wishlist-page">
    <div class="container">
      <div class="section-header">
        <a href="/" class="btn-back">← VOLVER A LA TIENDA</a>
        <h1>MIS FAVORITOS</h1>
        <p>Los productos que guardaste para después</p>
      </div>

      <div class="wishlist-content">
        <div id="wishlistItems" class="wishlist-items">
          <!-- Los productos se cargan dinámicamente con JavaScript -->
          <div class="loading-placeholder">
            <p>Cargando tus favoritos...</p>
          </div>
        </div>

        <div class="wishlist-actions">
          <button class="btn-secondary clear-wishlist" onclick="clearWishlist()">
            VACIAR FAVORITOS
          </button>
          <a href="#productos" class="btn-primary">
            SEGUIR COMPRANDO
          </a>
        </div>
      </div>
    </div>
  </main>

</Layout>

<script>
  // Función para vaciar el wishlist
  function clearWishlist() {
    if (confirm('¿Estás seguro de que querés vaciar tus favoritos?')) {
      localStorage.removeItem('wishlist');
      window.wishlistManager.wishlist = [];
      window.wishlistManager.updateUI();
    }
  }

  // Inicializar la página cuando se carga
  document.addEventListener('DOMContentLoaded', () => {
    // Forzar actualización del UI del wishlist
    if (window.wishlistManager) {
      window.wishlistManager.updateUI();
    }
  });
</script>

<style>
  .wishlist-page {
    padding: 2rem 0 6rem;
    min-height: 100vh;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h1 {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--blanco);
    margin-bottom: 1rem;
    font-family: 'Bebas Neue', sans-serif;
  }

  .section-header p {
    font-size: 1rem;
    color: var(--gris);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .wishlist-content {
    max-width: 1400px;
    margin: 0 auto;
  }

  .wishlist-items {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
    min-height: 200px;
  }

  /* Wishlist Item Card CSS */
  :global(.wishlist-item) {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--negro-suave);
    border: 1px solid var(--borde);
    border-radius: 8px;
    gap: 1rem;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  
  :global(.wishlist-item:hover) {
    border-color: var(--rojo);
    transform: translateY(-5px);
  }
  
  :global(.item-image img) {
    width: 100%;
    height: 250px;
    object-fit: cover;
    border-radius: 4px;
  }
  
  :global(.item-info h4) {
    font-size: 1.2rem;
    margin-bottom: 0.2rem;
    color: var(--blanco);
  }
  
  :global(.item-category) {
    color: var(--rojo);
    font-size: 0.8rem;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  
  :global(.item-price) {
    color: var(--blanco);
    font-weight: 600;
    font-size: 1.1rem;
  }
  
  :global(.item-actions) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: auto;
  }
  
  :global(.item-actions .btn-primary) {
    padding: 0.8rem;
    font-size: 0.8rem;
    background: var(--rojo);
    color: var(--blanco);
    border: none;
    cursor: pointer;
    text-align: center;
    transition: background 0.3s ease;
    text-transform: uppercase;
  }
  
  :global(.item-actions .btn-primary:hover) {
    background: var(--rojo-oscuro);
  }
  
  :global(.item-actions .remove-btn) {
    padding: 0.8rem;
    font-size: 0.8rem;
    background: transparent;
    color: var(--gris);
    border: 1px solid var(--borde);
    cursor: pointer;
    text-align: center;
    transition: all 0.3s ease;
    text-transform: uppercase;
  }
  
  :global(.item-actions .remove-btn:hover) {
    color: var(--rojo);
    border-color: var(--rojo);
  }

  .btn-back {
    display: inline-block;
    color: var(--gris);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.3s ease;
  }

  .btn-back:hover {
    color: var(--rojo);
  }

  .loading-placeholder {
    text-align: center;
    padding: 3rem;
    color: var(--gris);
  }

  .wishlist-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 0;
    border-top: 1px solid var(--borde);
  }

  .btn-primary,
  .btn-secondary {
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .btn-primary {
    background: var(--rojo);
    color: var(--blanco);
    border: none;
  }

  .btn-primary:hover {
    background: var(--rojo-oscuro);
  }

  .btn-secondary {
    background: transparent;
    color: var(--gris);
    border: 1px solid var(--borde);
  }

  .btn-secondary:hover {
    color: var(--rojo);
    border-color: var(--rojo);
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1rem;
    }

    .section-header {
      margin-bottom: 3rem;
    }

    .wishlist-actions {
      flex-direction: column;
      gap: 1rem;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
      text-align: center;
    }
  }
</style>
