---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase.js';
import ProductCard from '../components/ProductCard.astro';

export async function getStaticPaths() {
  // Para build-time generation o SSR
  return [];
}

const { id } = Astro.params;

// Obtener producto por ID
let product = null;
let relatedProducts = [];

try {
  if (supabase) {
    // Producto principal
    const { data: productData, error: productError } = await supabase
      .from('productos')
      .select('*')
      .eq('id', id)
      .single();

    if (productError) {
      console.error('Error al obtener producto:', productError);
    } else {
      product = productData;
    }

    // Productos recomendados (misma categoría primero, luego otros)
    if (product) {
      // 1. Intentar obtener de la misma categoría
      const { data: catData } = await supabase
        .from('productos')
        .select('*')
        .eq('categoria', product.categoria)
        .neq('id', id)
        .gt('stock', 0)
        .order('created_at', { ascending: false })
        .limit(4);

      let results = catData || [];

      // 2. Si hay menos de 4, rellenar con otros aleatorios
      if (results.length < 4) {
        const { data: othersData } = await supabase
          .from('productos')
          .select('*')
          .neq('id', id)
          .neq('categoria', product.categoria)
          .gt('stock', 0)
          .limit(4 - results.length);
        
        if (othersData) {
          results = [...results, ...othersData];
        }
      }

      relatedProducts = results;
    }
  }
} catch (err) {
  console.error('Error:', err);
}

const formatter = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  minimumFractionDigits: 0,
});

// URLs de imágenes (asumiendo campo adicional o array)
let productImages = product?.imagenes_url 
  ? [...(Array.isArray(product.imagenes_url) ? product.imagenes_url : [])] 
  : product?.imagen_url 
    ? [product.imagen_url] 
    : [];

// Inject image_back as the second image if it exists and is not already present
if (product?.image_back && !productImages.includes(product.image_back)) {
  if (productImages.length > 0) {
    productImages.splice(1, 0, product.image_back);
  } else {
    productImages.push(product.image_back);
  }
}
---

<Layout title={`${product?.nombre || 'Producto'} | MELROSE`}>
  <!-- Dynamic Meta Tags for SEO -->
  <head>
    <meta name="description" content={product?.descripcion || `Compra ${product?.nombre || 'producto'} en MELROSE. Calidad premium y estilo urbano.`} />
    <meta name="keywords" content={`${product?.nombre}, ${product?.categoria}, streetwear, moda urbana, MELROSE, Argentina, ropa premium`} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="product" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={`${product?.nombre || 'Producto'} | MELROSE`} />
    <meta property="og:description" content={product?.descripcion || `Compra ${product?.nombre || 'producto'} en MELROSE. Calidad premium y estilo urbano.`} />
    <meta property="og:image" content={productImages[0]} />
    <meta property="og:image:alt" content={product?.nombre || 'Producto'} />
    <meta property="og:site_name" content="MELROSE" />
    
    <!-- Twitter Card -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={`${product?.nombre || 'Producto'} | MELROSE`} />
    <meta property="twitter:description" content={product?.descripcion || `Compra ${product?.nombre || 'producto'} en MELROSE. Calidad premium y estilo urbana.`} />
    <meta property="twitter:image" content={productImages[0]} />
    
    <!-- Additional SEO -->
    <link rel="canonical" href={Astro.url} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="MELROSE" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Structured Data for Product -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org/",
        "@type": "Product",
        "name": product?.nombre || "",
        "description": product?.descripcion || "",
        "image": productImages,
        "category": product?.categoria || "",
        "offers": {
          "@type": "Offer",
          "price": product?.precio || 0,
          "priceCurrency": "ARS",
          "availability": product?.stock > 0 ? "https://schema.org/InStock" : "https://schema.org/OutOfStock"
        },
        "brand": {
          "@type": "Brand",
          "name": "MELROSE"
        }
      })}
    </script>
  </head>

  <main class="product-detail">
    {product ? (
      <>
        <!-- Breadcrumb -->
        <nav class="breadcrumb">
          <a href="/">Inicio</a>
          <span>/</span>
          <a href="#productos">{product.categoria}</a>
          <span>/</span>
          <span class="current">{product.nombre}</span>
        </nav>

        <!-- Producto Principal -->
        <section class="product-container">
          <div class="product-gallery">
            <div class="main-image">
              <img 
                src={productImages[0]} 
                alt={product.nombre}
                id="mainProductImage"
                loading="eager"
              />
            </div>
            
            {productImages.length > 1 && (
              <div class="thumbnail-grid">
                {productImages.map((img, index) => (
                  <button 
                    class={`thumbnail ${index === 0 ? 'active' : ''}`}
                    onclick={`changeMainImage('${img}')`}
                  >
                    <img src={img} alt={`${product.nombre} ${index + 1}`} />
                  </button>
                ))}
              </div>
            )}
          </div>

          <div class="product-info">
            <div class="product-header">
              <h1>{product.nombre}</h1>
              <p class="category">{product.categoria}</p>
              <div class="price">
                <span class="current">{formatter.format(product.precio)}</span>
              </div>
            </div>

            <div class="product-options">
              <div class="size-selector">
                <div class="label-row">
                  <label>TALLE</label>
                  <button id="openSizeGuide" class="size-guide-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 10H2a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h20a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2z"/>
                      <path d="M7 10v4"/>
                      <path d="M12 10v2"/>
                      <path d="M17 10v4"/>
                    </svg>
                    Ver guía de talles
                  </button>
                </div>
                <select id="sizeSelect">
                  {product?.talles && Array.isArray(product.talles) && product.talles.length > 0 ? (
                    <>
                      <option value="">Seleccionar talle</option>
                      {product.talles.map((talle) => (
                        <option value={talle}>{talle}</option>
                      ))}
                    </>
                  ) : (
                    <option value="">Sin stock de talles</option>
                  )}
                </select>
              </div>

              <div class="quantity-selector">
                <label>CANTIDAD</label>
                <input 
                  type="number" 
                  id="quantityInput"
                  min="1" 
                  max={product.stock} 
                  value="1" 
                />
              </div>
            </div>

            <div class="product-actions">
              <button 
                id="addToCartBtn"
                class={`btn-primary add-to-cart-btn ${(!product.talles || product.talles.length === 0) ? 'enabled' : ''}`}
                data-id={product.id}
                data-name={product.nombre}
                data-price={product.precio}
                data-stock={product.stock}
                data-image={productImages[0]}
                data-size={(!product.talles || product.talles.length === 0) ? 'Único' : ''}
                disabled={product.talles && product.talles.length > 0}
              >
                AGREGAR AL CARRITO
              </button>

              <button 
                class="btn-secondary whatsapp-btn"
                onclick="buyOnWhatsApp({
                  id: '${product.id}',
                  name: '${product.nombre}',
                  price: ${product.precio},
                  quantity: 1
                })"
              >
                COMPRAR POR WHATSAPP
              </button>
            </div>

            <div class="product-description">
              <h3>DESCRIPCIÓN</h3>
              <p>{product.descripcion || 'Producto premium de la colección MELROSE.'}</p>
            </div>

            <div class="product-meta">
              <div class="stock-info">
                <span class={`stock ${product.stock > 0 ? 'available' : 'out'}`}>
                  {product.stock > 0 ? `${product.stock} unidades disponibles` : 'AGOTADO'}
                </span>
              </div>
            </div>
          </div>
        </section>

        {/* Productos Recomendados */}
        {relatedProducts.length > 0 && (
          <section class="related-products">
            <div class="container">
              <div class="section-header">
                <h2>TAMBIÉN TE PUEDE GUSTAR</h2>
                <div class="header-line"></div>
              </div>
              <div class="products-grid related-grid">
                {relatedProducts.map((relatedProduct) => (
                  <ProductCard product={relatedProduct} />
                ))}
              </div>
            </div>
          </section>
        )}
      </>
    ) : (
      <div class="not-found">
        <h1>PRODUCTO NO ENCONTRADO</h1>
        <p>El producto que buscas no existe o fue removido.</p>
        <a href="#productos" class="btn-primary">VER CATÁLOGO</a>
      </div>
    )}
  </main>
</Layout>

<script>
  // Control de talle y habilitación de botón
  const sizeSelect = document.getElementById('sizeSelect');
  const addToCartBtn = document.getElementById('addToCartBtn');

  if (sizeSelect && addToCartBtn) {
    sizeSelect.addEventListener('change', () => {
      if (sizeSelect.value) {
        addToCartBtn.disabled = false;
        addToCartBtn.classList.add('enabled');
      } else {
        addToCartBtn.disabled = true;
        addToCartBtn.classList.remove('enabled');
      }
    });
  }

  // Cambiar imagen principal
  function changeMainImage(imageSrc) {
    const mainImage = document.getElementById('mainProductImage');
    if (mainImage) {
      mainImage.src = imageSrc;
      
      // Actualizar active thumbnail
      document.querySelectorAll('.thumbnail').forEach(thumb => {
        thumb.classList.remove('active');
      });
      event.target.closest('.thumbnail').classList.add('active');
    }
  }

  // Lógica para agregar al carrito con validación de talle
  if (addToCartBtn) {
    addToCartBtn.addEventListener('click', () => {
      const quantityInput = document.getElementById('quantityInput');
      
      if (!sizeSelect.value) {
        alert('Por favor selecciona un talle');
        return;
      }

      // Preparar datos para el carrito
      const cartData = {
        id: addToCartBtn.dataset.id,
        name: addToCartBtn.dataset.name,
        price: parseFloat(addToCartBtn.dataset.price),
        stock: parseInt(addToCartBtn.dataset.stock),
        image: addToCartBtn.dataset.image,
        size: sizeSelect.value || addToCartBtn.dataset.size || 'Único',
        quantity: parseInt(quantityInput?.value || "1")
      };

      console.log('📦 Melrose Admin: Agregando al carrito:', cartData);

      // Disparar evento personalizado para CartManager
      const cartEvent = new CustomEvent('addToCart', {
        detail: cartData
      });
      
      document.dispatchEvent(cartEvent);
    });
  }

  // Lógica Guía de Talles
  const openBtn = document.getElementById('openSizeGuide');
  const closeBtn = document.getElementById('closeSizeGuide');
  const modal = document.getElementById('sizeGuideModal');

  if (openBtn && modal) {
    const closeModal = () => {
      modal.classList.remove('active');
      setTimeout(() => {
        modal.style.display = 'none';
        document.body.style.overflow = '';
      }, 300);
    };

    openBtn.onclick = () => {
      modal.style.display = 'flex';
      setTimeout(() => modal.classList.add('active'), 10);
      document.body.style.overflow = 'hidden';
    };

    if (closeBtn) closeBtn.onclick = closeModal;

    modal.onclick = (e) => {
      if (e.target === modal) closeModal();
    };

    // Cerrar con Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('active')) {
        closeModal();
      }
    });
  }

  // Compra directa por WhatsApp
  function buyOnWhatsApp(product) {
    const sizeSelect = document.getElementById('sizeSelect');
    const quantityInput = document.getElementById('quantityInput');
    const selectedSize = sizeSelect?.value || 'No seleccionado';
    const selectedQuantity = quantityInput?.value || 1;
    
    const message = `Hola, me gustaría comprar:%0A${product.name} - Talle: ${selectedSize} - Cantidad: ${selectedQuantity}%0APrecio: $ ${(product.price * selectedQuantity).toLocaleString('es-AR')}`;
    window.open(`https://wa.me/5493624645328?text=${encodeURIComponent(message)}`, '_blank');
  }
</script>

