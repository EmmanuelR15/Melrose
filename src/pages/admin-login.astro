---
import Layout from '../layouts/Layout.astro';

// Check if already logged in
const isAdmin = Astro.cookies.get('admin_token')?.value === 'melrose_admin_2024';
if (isAdmin) {
  return Astro.redirect('/admin');
}
---

<Layout title="Admin Login | MELROSE">
  <main class="admin-login">
    <div class="login-container">
      <div class="login-card">
        <div class="login-header">
          <h1>ADMIN LOGIN</h1>
          <p>Acceso al panel de administración</p>
        </div>

        <form id="loginForm" class="login-form">
          <div class="form-group">
            <label for="password">Contraseña</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              required
              placeholder="Ingrese la contraseña"
            >
          </div>
          
          <button type="submit" class="login-btn">
            ACCEDER
          </button>
        </form>

        <div class="login-footer">
          <a href="/" class="back-link">Volver al sitio</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const loginForm = document.getElementById('loginForm');
    
    loginForm.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const password = e.target.password.value;
      
      // Simple password check (in production, use proper authentication)
      if (password === 'melrose_admin_2024') {
        // Set admin token cookie
        document.cookie = 'admin_token=melrose_admin_2024; path=/; max-age=86400'; // 24 hours
        
        // Redirect to admin panel
        window.location.href = '/admin';
      } else {
        // Show error
        const errorDiv = document.createElement('div');
        errorDiv.className = 'login-error';
        errorDiv.textContent = 'Contraseña incorrecta';
        errorDiv.style.cssText = `
          color: var(--rojo);
          margin-top: 1rem;
          text-align: center;
          font-weight: 600;
        `;
        
        // Remove existing error if any
        const existingError = loginForm.querySelector('.login-error');
        if (existingError) {
          existingError.remove();
        }
        
        loginForm.appendChild(errorDiv);
        
        // Clear password field
        e.target.password.value = '';
        
        // Remove error after 3 seconds
        setTimeout(() => {
          if (errorDiv.parentNode) {
            errorDiv.remove();
          }
        }, 3000);
      }
    });
  });
</script>

<style>
  .admin-login {
    min-height: 100vh;
    background: var(--negro);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .login-container {
    width: 100%;
    max-width: 400px;
  }

  .login-card {
    background: var(--negro-suave);
    border: 1px solid var(--borde);
    border-radius: 12px;
    padding: 3rem 2rem;
    text-align: center;
  }

  .login-header h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    letter-spacing: 0.1em;
    color: var(--blanco);
    margin-bottom: 0.5rem;
  }

  .login-header p {
    color: var(--gris);
    margin-bottom: 2rem;
  }

  .login-form {
    margin-bottom: 2rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--gris);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .form-group input {
    width: 100%;
    padding: 1rem;
    background: var(--negro);
    border: 1px solid var(--borde);
    border-radius: 6px;
    color: var(--blanco);
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--rojo);
  }

  .login-btn {
    width: 100%;
    padding: 1rem;
    background: var(--rojo);
    color: var(--blanco);
    border: none;
    border-radius: 6px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
  }

  .login-btn:hover {
    background: var(--rojo-oscuro);
    transform: translateY(-2px);
  }

  .login-btn:active {
    transform: translateY(0);
  }

  .login-footer {
    border-top: 1px solid var(--borde);
    padding-top: 1.5rem;
  }

  .back-link {
    color: var(--gris);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .back-link:hover {
    color: var(--rojo);
  }

  @media (max-width: 480px) {
    .login-card {
      padding: 2rem 1.5rem;
    }
    
    .login-header h1 {
      font-size: 2rem;
    }
  }
</style>
